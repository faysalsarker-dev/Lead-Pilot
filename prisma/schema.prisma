
generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum TemplateType {
  INITIAL
  FOLLOWUP_1
  FOLLOWUP_2
  FINAL
}

enum CampaignStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

enum EmailQueueStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum NotificationType {
  REPLY_RECEIVED
  FOLLOWUP_SENT
  CAMPAIGN_COMPLETED
  LEAD_BOUNCED
  CAMPAIGN_PAUSED
  AI_ENRICHMENT_DONE
  // ✅ ADDED
  FOLLOWUP_DUE          // remind user a manual follow-up is due today
  AI_AGENT_COMPLETED    // Hermes finished a lead collection job
  AI_AGENT_FAILED       // Hermes job errored
}

enum UserStatus {
  ACTIVE
  TRIAL_EXPIRED
  PAUSED_FOR_BILLING
  BLOCKED
}

enum LeadStatus {
  NEW
  CONTACTED
  ACTIVE
  INTERESTED
  CONVERTED
  REJECTED
  GHOST
}

enum LeadSource {
  FACEBOOK
  GOOGLE_MAPS
  LINKEDIN
  INSTAGRAM
  TWITTER
  TIKTOK
  REFERRAL
  MANUAL
  CSV_IMPORT
  FACEBOOK_ADS
  COLD_CALL
  EVENT
  AI_AGENT      // ✅ ADDED — leads collected by Hermes sniper
  OTHER
}

enum WorkType {
  SERVICE
  PROJECT
}

enum BudgetRange {
  UNKNOWN
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum Urgency {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EnrichmentStatus {
  PENDING
  RUNNING
  DONE
  FAILED
  SKIPPED
}

enum MailboxType {
  GMAIL_IMAP
  GMAIL_OAUTH
  CUSTOM_SMTP
}

enum MailboxStatus {
  UNTESTED
  TESTING
  CONNECTED
  FAILED
}

// ✅ ADDED — AI agent job lifecycle
enum AgentJobStatus {
  QUEUED      // created, not started yet
  RUNNING     // currently scraping
  COMPLETED   // finished, CSV ready
  FAILED      // error occurred
  CANCELLED   // user cancelled
}

// ✅ ADDED — manual follow-up status
enum FollowUpStatus {
  PENDING     // scheduled, not done yet
  SENT        // email sent for this follow-up
  SKIPPED     // user dismissed it
}

// ============================================
// MODELS
// ============================================

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  password       String
  name           String
  image          String?
  service        String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  isActive       Boolean    @default(true)
  status         UserStatus?
  currentStreak  Int        @default(0)
  longestStreak  Int        @default(0)
  lastLoggedInAt DateTime?

  // Settings
  autoEnrich          Boolean @default(true)
  defaultSendWindow   String  @default("09:00-11:00")
  webPushEnabled      Boolean @default(false)
  webPushSubscription Json?

  // Relations
  mailboxes     Mailbox[]
  leads         Lead[]
  templates     Template[]
  campaigns     Campaign[]
  notifications Notification[]
  followUps     FollowUp[]     
  aiAgentJobs   AIAgentJob[]   

  @@index([email])
  @@index([createdAt])
}



model Mailbox {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  label     String
  fromName  String?
  fromEmail String?   // hello@yourdomain.com — used as From address for CUSTOM_SMTP
  replyTo   String?
  type      MailboxType
  isDefault Boolean     @default(false)
  isActive  Boolean     @default(true)

  connectionStatus MailboxStatus @default(UNTESTED)
  lastTestedAt     DateTime?
  lastError        String?

  // Gmail (GMAIL_IMAP + GMAIL_OAUTH)
  gmailEmail        String?
  gmailRefreshToken String?   // AES-256-GCM encrypted, GMAIL_OAUTH only

  // SMTP — used by CUSTOM_SMTP and GMAIL_IMAP
  smtpHost    String?
  smtpPort    Int?
  smtpUser    String?
  smtpPassEnc String?   // AES-256-GCM encrypted
  smtpSsl     Boolean   @default(true)

  // IMAP — on-demand reply count only, no background sync, no email storage
  imapEnabled Boolean @default(false)
  imapHost    String?
  imapPort    Int?
  imapUser    String?
  imapPassEnc String?   // AES-256-GCM encrypted
  imapSsl     Boolean   @default(true)

  sendCountToday Int      @default(0)
  dailySendLimit Int      @default(400)
  lastSentAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns  Campaign[]
  emailQueue EmailQueue[]

  @@unique([userId, label])
  @@index([userId])
  @@index([userId, isActive])
  @@index([userId, isDefault])
  @@index([userId, type])
  @@index([userId, imapEnabled])
}


model Lead {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── IDENTITY ──────────────────────────────
  name         String
  businessName String
  businessType String?
  jobTitle     String?
  avatarUrl    String?

  // ── CONTACT ───────────────────────────────
  email           String?
  emailVerified   Boolean @default(false)
  phone           String?
  whatsapp        String?
  whatsappOptedIn Boolean @default(false)

  facebookUrl     String?
  instagramHandle String?
  linkedinUrl     String?
  twitterHandle   String?
  youtubeUrl      String?
  tiktokHandle    String?

  website            String?
  googleMapsUrl      String?
  googleMapsPlaceId  String?

  // ── LOCATION ──────────────────────────────
  country  String?
  city     String?
  area     String?
  timezone String?

  // ── QUICK CAPTURE ─────────────────────────
  quickNote    String?
  capturedFrom String?
  capturedAt   DateTime?

  // ── PROBLEMS ──────────────────────────────
  observedProblems String[]

  // ── CLASSIFICATION ────────────────────────
  workType    WorkType?
  budgetRange BudgetRange?
  urgency     Urgency?
  source      LeadSource?

  // ✅ ADDED — tags for flexible filtering
  // e.g. ["hot", "needs-website", "nz-client", "follow-up-week-3"]
  tags String[]

  // ── PIPELINE ──────────────────────────────
  status          LeadStatus @default(NEW)
  statusUpdatedAt DateTime   @default(now())

  isActive       Boolean   @default(false)
  hasReplied     Boolean   @default(false)
  isInterested   Boolean   @default(false)
  unsubscribed   Boolean   @default(false)

  campaignRunning Boolean   @default(false)
  lastContactedAt DateTime?
  totalEmailsSent Int       @default(0)
  lastReplyAt     DateTime?

  priority   Priority @default(MEDIUM)
  isPinned   Boolean  @default(false)
  isFavorite Boolean  @default(false)

  // ── AI ENRICHMENT ─────────────────────────
  enrichmentStatus EnrichmentStatus @default(PENDING)
  enrichmentError  String?
  aiEnrichedAt     DateTime?
  aiScore          Int?
  aiSummary        String?
  aiPainPoints     String[]
  aiEmailOpener    String?
  aiAdCopy         String?

  notes         String?
  internalLabel String?

  softDeleted Boolean   @default(false)
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  campaignLeads CampaignLead[]
  notifications Notification[]
  emailQueue    EmailQueue[]
  followUps     FollowUp[]     // ✅ ADDED

  @@unique([userId, email])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, source])
  @@index([userId, priority])
  @@index([userId, isActive])
  @@index([userId, hasReplied])
  @@index([userId, isInterested])
  @@index([userId, isPinned])
  @@index([userId, workType])
  @@index([userId, enrichmentStatus])
  @@index([userId, softDeleted])
  @@index([userId, campaignRunning])
  @@index([createdAt])
  @@index([statusUpdatedAt])
  @@index([tags])              // ✅ ADDED — GIN index for array search
  @@index([observedProblems])
}

model Template {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name     String
  type     TemplateType
  subjectA String
  subjectB String?
  body     String

  // ✅ ADDED — tells the UI which variables this template uses
  // e.g. ["business_name", "city", "pain_point", "your_name"]
  // Auto-extracted from body on save, shown in template editor
  usedVariables String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaignsAsInitial   Campaign[] @relation("InitialTemplate")
  campaignsAsFollowup1 Campaign[] @relation("Followup1Template")
  campaignsAsFollowup2 Campaign[] @relation("Followup2Template")
  campaignsAsFinal     Campaign[] @relation("FinalTemplate")
  emailQueue           EmailQueue[]

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([userId, type])
}

model Campaign {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name   String
  status CampaignStatus @default(DRAFT)

  // ✅ ADDED — targeting info (used by AI agent + labelling)
  category String?   // e.g. "car wash"
  country  String?   // e.g. "New Zealand"
  city     String?   // e.g. "Auckland"

  mailboxId String
  mailbox   Mailbox @relation(fields: [mailboxId], references: [id])

  initialTemplateId   String
  initialTemplate     Template  @relation("InitialTemplate", fields: [initialTemplateId], references: [id])
  followup1TemplateId String?
  followup1Template   Template? @relation("Followup1Template", fields: [followup1TemplateId], references: [id])
  followup2TemplateId String?
  followup2Template   Template? @relation("Followup2Template", fields: [followup2TemplateId], references: [id])
  finalTemplateId     String?
  finalTemplate       Template? @relation("FinalTemplate", fields: [finalTemplateId], references: [id])

  followup1Days Int @default(3)
  followup2Days Int @default(5)
  finalDays     Int @default(7)

  sendWindow String @default("09:00-11:00")

  totalSent    Int     @default(0)
  totalBounced Int     @default(0)
  autoPaused   Boolean @default(false)

  launchedAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  campaignLeads CampaignLead[]
  emailQueue    EmailQueue[]
  notifications Notification[]
  aiAgentJobs   AIAgentJob[]   // ✅ ADDED

  @@index([userId])
  @@index([status])
  @@index([mailboxId])
  @@index([launchedAt])
  @@index([createdAt])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model CampaignLead {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  assignedSubject String?

  sentAt          DateTime?
  openedAt        DateTime?
  repliedAt       DateTime?
  followup1SentAt DateTime?
  followup2SentAt DateTime?
  finalSentAt     DateTime?

  bounced      Boolean @default(false)
  unsubscribed Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([campaignId, leadId])
  @@index([campaignId])
  @@index([leadId])
  @@index([sentAt])
  @@index([repliedAt])
  @@index([bounced])
}

model EmailQueue {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  mailboxId  String
  mailbox    Mailbox  @relation(fields: [mailboxId], references: [id])
  templateId String
  template   Template @relation(fields: [templateId], references: [id])

  templateType TemplateType
  subject      String
  // ✅ NOTE: storing resolved body per lead is correct for audit trail
  // but consider a bodyHash field to deduplicate storage if scale becomes issue
  body         String
  bodyHash     String?  // ✅ ADDED — SHA256 of body, for dedup analytics

  scheduledAt DateTime
  status      EmailQueueStatus @default(PENDING)

  sentAt     DateTime?
  failedAt   DateTime?
  failReason String?
  retryCount Int @default(0)

  createdAt DateTime @default(now())

  @@index([campaignId])
  @@index([leadId])
  @@index([mailboxId])
  @@index([status])
  @@index([scheduledAt])
  @@index([status, scheduledAt])
  @@index([status, retryCount])
  @@index([createdAt])
}



model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId     String?
  lead       Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  campaignId String?
  campaign   Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  type    NotificationType
  message String
  isRead  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([leadId])
  @@index([campaignId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([userId, type])
}

// ✅ ADDED — Manual follow-up scheduling
// User picks a date per lead → cron checks daily → sends reminder notification
model FollowUp {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId      String
  lead        Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  scheduledAt DateTime       // user-chosen date/time (stored as UTC)
  note        String?        // optional reminder e.g. "Ask about their budget"
  status      FollowUpStatus @default(PENDING)
  completedAt DateTime?      // when user marked it done or email was sent

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([leadId])
  @@index([scheduledAt])                // cron: find all due follow-ups
  @@index([status])
  @@index([userId, status])             // "show me all my pending follow-ups"
  @@index([userId, scheduledAt])        // "what's due this week for me"
}

// ✅ ADDED — AI Agent (Hermes) job tracking
// Every lead sniper run is recorded here
// Cron or webhook updates status as job progresses
model AIAgentJob {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  // what the agent was asked to find
  category   String            // e.g. "car wash"
  country    String?           // e.g. "New Zealand"
  city       String            // e.g. "Auckland"
  maxResults Int    @default(50)

  // job lifecycle
  status      AgentJobStatus @default(QUEUED)
  startedAt   DateTime?
  completedAt DateTime?
  errorMsg    String?

  // results summary
  totalFound  Int @default(0)  // raw results from Google Maps
  totalSaved  Int @default(0)  // after dedup + filter
  totalSkipped Int @default(0) // duplicates or no-website leads skipped

  // output — CSV file path on server or a public URL
  outputFile  String?

  // if user imported the CSV into a campaign, track it
  importedAt         DateTime?
  importedToCampaign String?   // campaignId it was imported into

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([campaignId])
  @@index([status])
  @@index([userId, status])
  @@index([createdAt])
}
